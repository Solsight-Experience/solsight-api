# Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=your_password_here
# DATABASE_NAME=sol_sight

DATABASE_URL=postgresql://postgres:password@localhost:5432/sol_sight?schema=public

# Redis Configuration
# Format: redis://localhost:6379 or redis://:password@host:port for auth
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# MongoDB Configuration
MONGO_USERNAME=your_mongo_username
MONGO_PASSWORD=your_mongo_password

# Solana Configuration
# Nên dùng rpc khác, rpc public của solana chạy không nổi
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_PROGRAM_ID=11111111111111111111111111111111

HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key
HELIUS_API_KEY=your_helius_api_key

# Jupiter Configuration
# Base URL for price / token list / limit-order endpoints
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=
JUPITER_TOKEN_SEARCH_API=https://lite-api.jup.ag/tokens/v2/search?query=
JUPITER_QUOTE_API_URL=https://api.jup.ag/swap/v1/quote

# Coingecko Configuration
COINGECKO_LIST_API=https://api.coingecko.com/api/v3/coins/list?include_platform=true

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# API Configuration
API_PREFIX=api
API_VERSION=v1

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# OpenAI (default AI provider) Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Jupiter Trigger API
JUPITER_TRIGGER_API_URL=https://api.jup.ag/trigger/v1
JUPITER_API_KEY=your_jupiter_api_key

# Birdeye API Configuration
BIRDEYE_API_KEY=your_birdeye_api_key
BIRDEYE_API_URL=https://public-api.birdeye.so

MONGODB_URI=mongodb+srv://your_mongo_username:your_mongo_password@cluster0.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=solsight_rag
MONGODB_VECTOR_COLLECTION=rag_documents
MONGODB_VECTOR_INDEX=vector_index

EMBEDDING_PROVIDER=gemini
EMBEDDING_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
EMBEDDING_API_KEY=your_gemini_api_key
EMBEDDING_MODEL=gemini-embedding-001

# Zalo OA Bot Configuration
ZALO_BOT_TOKEN=your-zalo-oa-access-token-here

# Email (Resend) Configuration
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_ADDRESS=alerts@solsight.app
APP_BASE_URL=http://localhost:3000
