# Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=sol_sight

# Redis Configuration
# Format: redis://localhost:6379 or redis://:password@host:port for auth
REDIS_URL=redis://localhost:6379

# Solana Configuration
# Nên dùng rpc khác, rpc public của solana chạy không nổi
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
HELIUS_RPC_URL=
HELIUS_API_KEY=

# Jupiter Configuration
JUPITER_API_URL=https://quote-api.jup.ag/v6
JUPITER_TOKEN_SEARCH_API='https://lite-api.jup.ag/tokens/v2/search?query='
JUPITER_PRICE_API_URL=https://price.jup.ag/v4

# Coingecko Configuration
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_LIST_API=https://api.coingecko.com/api/v3/coins/list
COINGECKO_API_KEY=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# API Configuration
API_PREFIX=api
API_VERSION=v1

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# LLM (Large Language Model) Configuration
LLM_API_KEY=your-llm-api-key-here
LLM_API_URL=https://api.openai.com/v1/ # Reqruires trailing slash
LLM_MODEL=gpt-4o
LLM_TIMEOUT_MS=30000
