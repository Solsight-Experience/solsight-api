# Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=your_password_here
# DATABASE_NAME=sol_sight

DATABASE_URL=postgresql://postgres:password@localhost:5432/sol_sight?schema=public

# Redis Configuration
# Format: redis://localhost:6379 or redis://:password@host:port for auth
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Solana Configuration
# Nên dùng rpc khác, rpc public của solana chạy không nổi
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key
HELIUS_API_KEY=your_helius_api_key

# Insurance Fund staking
IF_PROGRAM_ID=4tsHWpfGh94M3gmDBYj96jquEpGbtyLYz4q87roAXbZU
IF_AUTHORITY=HJnpCRqahd2Zunhx1VyY9d9Hj7UyLSNWQEavybJC3MSa

# Billing — wallet address that receives SOL payments for paid credits
MERCHANT_WALLET=11111111111111111111111111111111

# Jupiter Configuration
# Base URL for price / token list / limit-order endpoints
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=

# Jito Tip-Floor Feed (public, unauthenticated)
# Used by GET /swap/info to seed the auto-tip suggestion.
JITO_TIP_FLOOR_URL=https://bundles.jito.wtf/api/v1/bundles/tip_floor

# Solsight Executor Configuration
SOLSIGHT_EXECUTOR_API_URL=http://localhost:8080
SOLSIGHT_EXECUTOR_API_KEY=

# Kora Paymaster Configuration
# Leave KORA_RPC_URL blank to disable gasless transactions (KoraService.isEnabled() returns false).
# KORA_API_KEY and KORA_HMAC_SECRET are only required if the Kora server enforces them.
KORA_RPC_URL=
KORA_API_KEY=
KORA_HMAC_SECRET=

# Coingecko Configuration
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# API Configuration
API_PREFIX=api
API_VERSION=v1

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# OpenAI (default AI provider) Configuration
# EMBEDDING_* vars use the same SDK — fallback to OPENAI_* values if not set
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

EMBEDDING_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
EMBEDDING_API_KEY=your_gemini_api_key
EMBEDDING_MODEL=gemini-embedding-001

# Jupiter Trigger API
JUPITER_TRIGGER_API_URL=https://api.jup.ag/trigger/v1
JUPITER_API_KEY=your_jupiter_api_key

# Birdeye API Configuration
BIRDEYE_API_KEY=your_birdeye_api_key
BIRDEYE_API_URL=https://public-api.birdeye.so

# Telegram Bot Configuration
# Create a bot via @BotFather on Telegram to get the token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Email (Resend) Configuration
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_ADDRESS=onboarding@resend.dev
APP_BASE_URL=http://localhost:3001
