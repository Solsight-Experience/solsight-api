# Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=sol_sight

# Redis Configuration
# Format: redis://localhost:6379 or redis://:password@host:port for auth
REDIS_URL=redis://localhost:6379

# Solana Configuration
# Nên dùng rpc khác, rpc public của solana chạy không nổi
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
HELIUS_RPC_URL=
HELIUS_API_KEY=

# Jupiter Configuration
# Base URL for price / token list / limit-order endpoints
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=
# Optional: separate URL and key for swap quote + transaction endpoints.
# Swap endpoints are rate-limited on the free tier; get a key at https://dev.jup.ag
# If unset, falls back to JUPITER_API_URL / JUPITER_API_KEY above.
JUPITER_SWAP_API_URL=
JUPITER_SWAP_API_KEY=

# Jito Tip-Floor Feed (public, unauthenticated)
# Used by GET /swap/info to seed the auto-tip suggestion.
JITO_TIP_FLOOR_URL=https://bundles.jito.wtf/api/v1/bundles/tip_floor

# Executor Configuration
# Executor provider: jupiter (default) or solsight
EXECUTOR_PROVIDER=jupiter

# Solsight Executor Configuration
SOLSIGHT_EXECUTOR_API_URL=http://localhost:8080
SOLSIGHT_EXECUTOR_API_KEY=

# Kora Paymaster Configuration
# Leave KORA_RPC_URL blank to disable gasless transactions (KoraService.isEnabled() returns false).
# KORA_API_KEY and KORA_HMAC_SECRET are only required if the Kora server enforces them.
KORA_RPC_URL=
KORA_API_KEY=
KORA_HMAC_SECRET=

# Coingecko Configuration
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_LIST_API=https://api.coingecko.com/api/v3/coins/list?include_platform=true
COINGECKO_API_KEY=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# API Configuration
API_PREFIX=api
API_VERSION=v1

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# OpenAI (default AI provider) Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# Zalo OA Bot Configuration
ZALO_BOT_TOKEN=your-zalo-oa-access-token-here

# Email (Resend) Configuration
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_ADDRESS=alerts@solsight.app
APP_BASE_URL=http://localhost:3000
